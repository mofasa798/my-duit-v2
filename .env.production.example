APP_NAME=MyDuit
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://myduit.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance
APP_MAINTENANCE_DRIVER=file

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=warning

# Database — SQLite (production)
DB_CONNECTION=sqlite
# For MySQL/PostgreSQL, uncomment and configure:
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=myduit
# DB_USERNAME=myduit
# DB_PASSWORD=secret

# Sessions
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.example.com

# Cache & Queue
CACHE_STORE=database
QUEUE_CONNECTION=database

# Broadcasting
BROADCAST_CONNECTION=log

# Filesystem
FILESYSTEM_DISK=local

# Email
MAIL_MAILER=log
# MAIL_HOST=mailpit
# MAIL_PORT=1025
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_ENCRYPTION=null
# MAIL_FROM_ADDRESS="hello@example.com"
# MAIL_FROM_NAME="${APP_NAME}"
